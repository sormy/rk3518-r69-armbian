#!/bin/sh
# Build + install the IR-remote driver as a DKMS module from the patched source the image stages at
# /usr/src/rockchip-pwm-remotectl-r69-1.0/. Run automatically on first boot by r69-firstboot (the
# remote + power button must work out of the box); also runnable by hand to rebuild/troubleshoot.
# Fully offline — it NEVER downloads; it errors out if the build tools/headers aren't already present
# (the recommended base image ships them).
#
# The stock remotectl-pwm is built into the kernel and fails to claim the shared PWM-block IRQ (it
# omits IRQF_SHARED while the voltage-regulator PWMs already hold that IRQ with it). The staged source
# is patched (firmware/ir/r69.patch) to share the IRQ and rename the driver (remotectl-pwm-r69) so it
# binds the otherwise-unbound pwm3. With remote_support_psci=1 in the DTB, the power key then wakes the box.
# Full story: HOW-IT-WAS-DONE.md.
set -e
[ "$(id -u)" = 0 ] || { echo "run as root"; exit 1; }

VER=1.0
NAME=rockchip-pwm-remotectl-r69
SRC=/usr/src/$NAME-$VER
KREL=$(uname -r)

[ -f "$SRC/dkms.conf" ] || { echo "vendored source missing at $SRC (build the image with build-image.sh)"; exit 1; }

echo "[1/3] prerequisites (offline — this script never downloads)"
need=""
[ -d "/usr/src/linux-headers-$KREL" ] || need="$need linux-headers-$KREL"
for t in dkms gcc make; do command -v $t >/dev/null || need="$need $t"; done
[ -n "$need" ] && { echo "missing build prerequisites:$need — install them, then re-run"; exit 1; }

echo "[2/3] dkms build + install"
dkms remove  -m "$NAME" -v "$VER" --all 2>/dev/null || true
dkms add     -m "$NAME" -v "$VER"
dkms build   -m "$NAME" -v "$VER"
dkms install -m "$NAME" -v "$VER"

echo "[3/3] auto-load at boot + load now"
echo rockchip_pwm_remotectl_r69 > /etc/modules-load.d/rockchip-pwm-remotectl-r69.conf
modprobe rockchip_pwm_remotectl_r69 2>/dev/null || true

echo
echo "Done. The remote's IR input device appears as 'remotectl-pwm-r69' (DKMS rebuilds it on kernel updates)."
echo "The power key now sleeps/wakes the box. Test keys: apt-get install -y evtest && evtest /dev/input/event4"
